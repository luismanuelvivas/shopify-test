<div
  class="cart-progress"
  data-cart-progress
  data-thresholds="10000,15000,20000"
  data-max-threshold="20000"
  data-gift-variant-id="0"
>
  <p class="cart-progress__message" data-cart-progress-message></p>
  <div
    class="cart-progress__track"
    role="progressbar"
    aria-label="Cart rewards progress"
    aria-valuemin="0"
    aria-valuemax="20000"
    aria-valuenow="0"
  >
    <div class="cart-progress__fill" data-cart-progress-fill></div>
    <div class="cart-progress__checkpoint" style="left: 33.333%">
      <span class="cart-progress__dot" data-cart-progress-dot="0"></span>
    </div>
    <div class="cart-progress__checkpoint" style="left: 66.666%">
      <span class="cart-progress__dot" data-cart-progress-dot="1"></span>
    </div>
    <div class="cart-progress__checkpoint" style="left: 100%">
      <span class="cart-progress__dot" data-cart-progress-dot="2"></span>
    </div>
  </div>
  <div class="cart-progress__labels" aria-hidden="true">
    <span class="cart-progress__label" data-cart-progress-label="0">Free shipping</span>
    <span class="cart-progress__label" data-cart-progress-label="1">20% off</span>
    <span class="cart-progress__label" data-cart-progress-label="2">Free gift</span>
  </div>
</div>
